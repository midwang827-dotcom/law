<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>行政复议文书练习系统</title>
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg: #fafaf8;
  --surface: #ffffff;
  --surface2: #f4f3ef;
  --border: rgba(0,0,0,0.1);
  --border2: rgba(0,0,0,0.18);
  --text: #1a1a18;
  --text2: #5a5a56;
  --text3: #9a9a94;
  --purple: #3C3489;
  --purple-light: #EEEDFE;
  --purple-mid: #534AB7;
  --green: #0F6E56;
  --green-light: #E1F5EE;
  --blue-light: #E6F1FB;
  --blue: #185FA5;
  --amber-light: #FAEEDA;
  --amber: #854F0B;
  --radius: 10px;
  --radius-sm: 6px;
}

body {
  font-family: 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans SC', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  line-height: 1.6;
}

/* NAV */
nav {
  background: var(--surface);
  border-bottom: 0.5px solid var(--border);
  padding: 0 2rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 56px;
  position: sticky;
  top: 0;
  z-index: 100;
}
.nav-brand { font-size: 16px; font-weight: 600; color: var(--purple); display: flex; align-items: center; gap: 8px; }
.nav-brand .badge { font-size: 11px; font-weight: 500; background: var(--purple-light); color: var(--purple); padding: 2px 8px; border-radius: 10px; }
.nav-links { display: flex; gap: 0; }
.nav-link { padding: 0 14px; height: 56px; display: flex; align-items: center; font-size: 14px; color: var(--text2); cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.15s; background: none; border-top: none; border-left: none; border-right: none; font-family: inherit; }
.nav-link:hover { color: var(--text); }
.nav-link.active { color: var(--purple); border-bottom-color: var(--purple); font-weight: 500; }

/* PAGES */
.page { display: none; }
.page.active { display: block; }

/* HOME PAGE */
.hero {
  max-width: 760px;
  margin: 0 auto;
  padding: 4rem 2rem 2rem;
}
.hero-tag { display: inline-block; background: var(--purple-light); color: var(--purple); font-size: 12px; font-weight: 500; padding: 4px 12px; border-radius: 10px; margin-bottom: 1.5rem; }
.hero h1 { font-size: 36px; font-weight: 700; line-height: 1.25; margin-bottom: 1rem; color: var(--text); letter-spacing: -0.5px; }
.hero h1 span { color: var(--purple); }
.hero p { font-size: 16px; color: var(--text2); max-width: 580px; margin-bottom: 2rem; line-height: 1.7; }
.hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; gap: 6px; padding: 10px 22px; border-radius: var(--radius-sm); font-size: 14px; font-weight: 500; cursor: pointer; transition: all 0.15s; font-family: inherit; border: none; text-decoration: none; }
.btn-primary { background: var(--purple); color: #fff; }
.btn-primary:hover { background: #26215C; }
.btn-outline { background: transparent; color: var(--text); border: 0.5px solid var(--border2); }
.btn-outline:hover { background: var(--surface2); }
.btn-green { background: var(--green); color: #fff; }
.btn-green:hover { background: #085041; }
.btn-green:disabled { background: var(--surface2); color: var(--text3); cursor: not-allowed; }
.btn-sm { padding: 7px 14px; font-size: 13px; }

.features {
  max-width: 760px;
  margin: 0 auto;
  padding: 2rem 2rem 4rem;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 16px;
}
.feature-card {
  background: var(--surface);
  border: 0.5px solid var(--border);
  border-radius: var(--radius);
  padding: 1.25rem;
}
.feature-icon { font-size: 22px; margin-bottom: 10px; }
.feature-title { font-size: 15px; font-weight: 600; margin-bottom: 6px; }
.feature-desc { font-size: 13px; color: var(--text2); line-height: 1.6; }

.disclaimer {
  max-width: 760px;
  margin: 0 auto 3rem;
  padding: 0 2rem;
}
.disclaimer-box {
  background: var(--amber-light);
  border: 0.5px solid #FAC775;
  border-radius: var(--radius);
  padding: 1rem 1.25rem;
  font-size: 13px;
  color: var(--amber);
  line-height: 1.7;
}
.disclaimer-box strong { display: block; margin-bottom: 4px; font-size: 14px; }

/* HELP PAGE */
.help-wrap {
  max-width: 720px;
  margin: 0 auto;
  padding: 3rem 2rem;
}
.help-wrap h2 { font-size: 24px; font-weight: 700; margin-bottom: 0.5rem; }
.help-wrap .subtitle { font-size: 15px; color: var(--text2); margin-bottom: 2.5rem; }
.help-section { margin-bottom: 2rem; }
.help-section h3 { font-size: 16px; font-weight: 600; margin-bottom: 0.75rem; display: flex; align-items: center; gap: 8px; }
.help-section p, .help-section li { font-size: 14px; color: var(--text2); line-height: 1.8; }
.help-section ul, .help-section ol { padding-left: 1.25rem; }
.help-section li { margin-bottom: 4px; }
.step-guide { display: flex; flex-direction: column; gap: 10px; }
.step-guide-item { display: flex; gap: 12px; background: var(--surface); border: 0.5px solid var(--border); border-radius: var(--radius); padding: 12px 14px; }
.step-num { width: 26px; height: 26px; border-radius: 50%; background: var(--purple); color: #fff; font-size: 12px; font-weight: 600; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.step-info { flex: 1; }
.step-info strong { font-size: 14px; font-weight: 600; display: block; margin-bottom: 2px; }
.step-info span { font-size: 13px; color: var(--text2); }
.faq-item { border: 0.5px solid var(--border); border-radius: var(--radius-sm); margin-bottom: 8px; overflow: hidden; }
.faq-q { padding: 12px 14px; font-size: 14px; font-weight: 500; cursor: pointer; display: flex; justify-content: space-between; align-items: center; background: var(--surface); }
.faq-q:hover { background: var(--surface2); }
.faq-a { padding: 0 14px; font-size: 13px; color: var(--text2); line-height: 1.7; max-height: 0; overflow: hidden; transition: all 0.2s; }
.faq-a.open { padding: 10px 14px 14px; max-height: 300px; }

/* PRACTICE PAGE */
.practice-wrap {
  max-width: 760px;
  margin: 0 auto;
  padding: 2rem 1.5rem 4rem;
}

.progress-bar { display: flex; align-items: center; margin-bottom: 2.5rem; }
.step-dot { display: flex; flex-direction: column; align-items: center; gap: 5px; flex: 1; }
.dot { width: 30px; height: 30px; border-radius: 50%; border: 1.5px solid var(--border2); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 500; background: var(--surface); color: var(--text3); transition: all 0.2s; }
.dot.active { background: var(--purple); border-color: var(--purple); color: #fff; }
.dot.done { background: var(--green); border-color: var(--green); color: #fff; }
.dot-label { font-size: 11px; color: var(--text3); text-align: center; line-height: 1.3; max-width: 68px; }
.step-line { height: 1.5px; flex: 1; background: var(--border); margin-bottom: 20px; transition: background 0.2s; }
.step-line.done { background: var(--green); }

.card { background: var(--surface); border: 0.5px solid var(--border); border-radius: var(--radius); padding: 1.5rem; margin-bottom: 1rem; }
.section-title { font-size: 18px; font-weight: 600; margin-bottom: 1.25rem; }
.field-group { margin-bottom: 1rem; }
.field-label { font-size: 13px; color: var(--text2); margin-bottom: 5px; display: block; }
input[type=text], input[type=date], select, textarea {
  width: 100%; padding: 8px 10px;
  border: 0.5px solid var(--border2);
  border-radius: var(--radius-sm);
  background: var(--surface);
  color: var(--text);
  font-size: 14px;
  font-family: inherit;
  transition: border-color 0.15s;
}
input:focus, select:focus, textarea:focus { outline: none; border-color: var(--purple-mid); box-shadow: 0 0 0 3px rgba(83,74,183,0.1); }
textarea { min-height: 80px; resize: vertical; }
.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

.checkbox-group { display: flex; flex-direction: column; gap: 8px; }
.checkbox-item { display: flex; align-items: flex-start; gap: 10px; padding: 10px 12px; border: 0.5px solid var(--border); border-radius: var(--radius-sm); cursor: pointer; transition: all 0.15s; }
.checkbox-item:hover { background: var(--surface2); }
.checkbox-item.checked { border-color: var(--purple-mid); background: var(--purple-light); }
.checkbox-item input[type=checkbox] { margin-top: 2px; flex-shrink: 0; width: 15px; height: 15px; }
.checkbox-text { font-size: 14px; font-weight: 500; }
.checkbox-text small { display: block; font-size: 12px; color: var(--text2); margin-top: 2px; font-weight: 400; }

.rule-match { background: var(--surface2); border-left: 3px solid var(--purple); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; padding: 10px 14px; margin-bottom: 10px; }
.rule-match .rule-title { font-size: 14px; font-weight: 600; color: var(--purple); margin-bottom: 4px; }
.rule-match .rule-desc { font-size: 13px; color: var(--text2); line-height: 1.6; }

.timeline-item { display: flex; gap: 12px; margin-bottom: 8px; align-items: flex-start; }
.timeline-dot-wrap { display: flex; flex-direction: column; align-items: center; flex-shrink: 0; }
.t-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--purple); margin-top: 5px; }
.t-line { width: 1.5px; background: var(--border); height: 20px; margin-top: 3px; }

.doc-output {
  background: var(--surface2);
  border: 0.5px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 1.25rem;
  font-size: 13.5px;
  line-height: 1.9;
  white-space: pre-wrap;
  font-family: 'Noto Serif SC', 'SimSun', serif;
  min-height: 100px;
}

.info-box { background: var(--blue-light); border: 0.5px solid #B5D4F4; border-radius: var(--radius-sm); padding: 10px 14px; font-size: 13px; color: var(--blue); margin-bottom: 1rem; line-height: 1.6; }

.btn-row { display: flex; justify-content: space-between; align-items: center; margin-top: 1.5rem; gap: 8px; flex-wrap: wrap; }
.btn-row-right { display: flex; gap: 8px; flex-wrap: wrap; }

.loading-pulse { display: inline-flex; gap: 4px; align-items: center; }
.loading-pulse span { width: 6px; height: 6px; border-radius: 50%; background: currentColor; animation: pulse 1.2s infinite ease-in-out; }
.loading-pulse span:nth-child(2) { animation-delay: 0.2s; }
.loading-pulse span:nth-child(3) { animation-delay: 0.4s; }
@keyframes pulse { 0%,80%,100%{opacity:0.2;transform:scale(0.8)} 40%{opacity:1;transform:scale(1)} }

.tab-row { display: flex; border-bottom: 0.5px solid var(--border); margin-bottom: 1.25rem; }
.tab { padding: 8px 16px; font-size: 13px; cursor: pointer; border-bottom: 2px solid transparent; color: var(--text2); transition: all 0.15s; background: none; border-top: none; border-left: none; border-right: none; font-family: inherit; }
.tab.active { color: var(--purple); border-bottom-color: var(--purple); font-weight: 500; }

.empty-state { text-align: center; padding: 2.5rem 1rem; color: var(--text3); font-size: 14px; }
.empty-state .icon { font-size: 32px; margin-bottom: 8px; }

/* copy button */
.copy-btn { display: inline-flex; align-items: center; gap: 4px; font-size: 12px; padding: 4px 10px; border-radius: var(--radius-sm); border: 0.5px solid var(--border2); background: var(--surface); color: var(--text2); cursor: pointer; transition: all 0.15s; font-family: inherit; }
.copy-btn:hover { background: var(--surface2); }

footer {
  text-align: center;
  padding: 2rem;
  font-size: 12px;
  color: var(--text3);
  border-top: 0.5px solid var(--border);
  margin-top: 2rem;
}

@media (max-width: 600px) {
  .grid-2 { grid-template-columns: 1fr; }
  .hero h1 { font-size: 26px; }
  nav { padding: 0 1rem; }
  .nav-brand .badge { display: none; }
}
</style>
</head>
<body>

<nav>
  <div class="nav-brand">
    ⚖️ 行政复议文书练习系统
    <span class="badge">模拟练习</span>
  </div>
  <div class="nav-links">
    <button class="nav-link active" onclick="showPage('home')">首页</button>
    <button class="nav-link" onclick="showPage('practice')">开始练习</button>
    <button class="nav-link" onclick="showPage('help')">使用说明</button>
  </div>
</nav>

<!-- HOME PAGE -->
<div id="page-home" class="page active">
  <div class="hero">
    <div class="hero-tag">免费 · 开源 · 模拟练习</div>
    <h1>行政复议文书<br><span>智能练习平台</span></h1>
    <p>专为法律学习者设计的行政复议文书练习工具。输入模拟案件信息，系统自动生成时间轴、争议分析，并借助 AI 生成申请书与答复书草稿，帮助你掌握文书写作技巧。</p>
    <div class="hero-actions">
      <button class="btn btn-primary" onclick="showPage('practice')">▶ 开始练习</button>
      <button class="btn btn-outline" onclick="showPage('help')">查看使用说明</button>
    </div>
  </div>

  <div class="features">
    <div class="feature-card">
      <div class="feature-icon">📋</div>
      <div class="feature-title">结构化输入</div>
      <div class="feature-desc">6步向导式填写，逐步整理案件基本信息、时间轴与争议点。</div>
    </div>
    <div class="feature-card">
      <div class="feature-icon">📅</div>
      <div class="feature-title">自动时间轴</div>
      <div class="feature-desc">输入关键时间节点后，系统自动生成可视化案件时间轴，方便发现程序问题。</div>
    </div>
    <div class="feature-card">
      <div class="feature-icon">⚡</div>
      <div class="feature-title">规则自动匹配</div>
      <div class="feature-desc">勾选争议点后，系统自动匹配相关法律规则，提示可能的违法情形。</div>
    </div>
    <div class="feature-card">
      <div class="feature-icon">✦</div>
      <div class="feature-title">AI 生成文书</div>
      <div class="feature-desc">一键生成申请书与答复书草稿，同时练习两种视角，对比学习更高效。</div>
    </div>
    <div class="feature-card">
      <div class="feature-icon">🔒</div>
      <div class="feature-title">隐私安全</div>
      <div class="feature-desc">所有数据仅在本地处理，不储存任何用户信息，请放心使用模拟材料。</div>
    </div>
    <div class="feature-card">
      <div class="feature-icon">📱</div>
      <div class="feature-title">随时可用</div>
      <div class="feature-desc">单个 HTML 文件，无需安装，打开即用，支持电脑与手机浏览器。</div>
    </div>
  </div>

  <div class="disclaimer">
    <div class="disclaimer-box">
      <strong>⚠️ 重要声明</strong>
      本工具仅供法律学习与文书写作练习使用，所有案件信息均为模拟虚构，不涉及任何真实当事人及案件。AI 生成的文书草稿仅供参考练习，不构成任何法律意见或法律服务。如有真实法律需求，请咨询执业律师。
    </div>
  </div>
</div>

<!-- PRACTICE PAGE -->
<div id="page-practice" class="page">
  <div class="practice-wrap">
    <div class="progress-bar" id="progressBar"></div>
    <div id="stepContent"></div>
  </div>
</div>

<!-- HELP PAGE -->
<div id="page-help" class="page">
  <div class="help-wrap">
    <h2>使用说明</h2>
    <p class="subtitle">了解如何使用本系统进行行政复议文书练习</p>

    <div class="help-section">
      <h3>🧭 练习流程（共 6 步）</h3>
      <div class="step-guide">
        <div class="step-guide-item">
          <div class="step-num">1</div>
          <div class="step-info">
            <strong>案件基本信息</strong>
            <span>填写申请人（假名）、被申请人机关、行政行为类型及具体内容等基础信息。</span>
          </div>
        </div>
        <div class="step-guide-item">
          <div class="step-num">2</div>
          <div class="step-info">
            <strong>案件时间轴</strong>
            <span>填写各关键事件的时间节点，系统自动生成可视化时间轴。时间轴是发现程序违法的关键。</span>
          </div>
        </div>
        <div class="step-guide-item">
          <div class="step-num">3</div>
          <div class="step-info">
            <strong>争议点选择</strong>
            <span>勾选本案可能存在的程序或实体问题，支持多选。</span>
          </div>
        </div>
        <div class="step-guide-item">
          <div class="step-num">4</div>
          <div class="step-info">
            <strong>法律规则匹配</strong>
            <span>系统根据已勾选的争议点，自动匹配相关法律规则并生成分析说明。</span>
          </div>
        </div>
        <div class="step-guide-item">
          <div class="step-num">5</div>
          <div class="step-info">
            <strong>生成申请人文书</strong>
            <span>点击"AI 生成申请书"，系统自动生成行政复议申请书草稿，包含复议请求与事实理由。</span>
          </div>
        </div>
        <div class="step-guide-item">
          <div class="step-num">6</div>
          <div class="step-info">
            <strong>生成被申请人文书</strong>
            <span>点击"AI 生成答复书"，从被申请人视角生成答复书，用于对比练习两种立场的写作方式。</span>
          </div>
        </div>
      </div>
    </div>

    <div class="help-section" style="margin-top:2rem;">
      <h3>❓ 常见问题</h3>
      <div class="faq-item">
        <div class="faq-q" onclick="toggleFaq(this)">AI 生成文书需要网络吗？<span>＋</span></div>
        <div class="faq-a">是的，AI 文书生成功能需要连接互联网，因为它会调用 Claude AI 接口。时间轴生成、规则匹配等功能无需联网。</div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="toggleFaq(this)">我填写的信息会被保存吗？<span>＋</span></div>
        <div class="faq-a">不会。本工具不包含任何数据库或服务器，所有填写的信息仅存在于当前浏览器页面中，关闭页面后即消失。</div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="toggleFaq(this)">可以用于真实案件吗？<span>＋</span></div>
        <div class="faq-a">不建议。本工具仅供学习练习使用，AI 生成的文书草稿可能存在不准确之处，真实案件请务必咨询执业律师。</div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="toggleFaq(this)">哪些行政行为类型适合练习？<span>＋</span></div>
        <div class="faq-a">系统预设了行政处罚、行政强制、不履行职责、信息公开、行政许可五种类型。其中行政处罚（尤其是交通类）的练习素材最为丰富，建议初学者从此开始。</div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="toggleFaq(this)">如何获得最好的练习效果？<span>＋</span></div>
        <div class="faq-a">建议先手写一份申请书草稿，再使用本系统生成 AI 版本进行对比。重点关注：争议点是否遗漏、理由是否充分、文书格式是否规范。</div>
      </div>
    </div>

    <div class="help-section" style="margin-top:2rem;">
      <h3>📖 行政复议基础知识</h3>
      <ul>
        <li>行政复议是公民、法人或其他组织对行政机关的具体行政行为不服时，依法向上级行政机关申请复查的制度。</li>
        <li>申请人需在知悉行政行为之日起 <strong>60日内</strong> 提出复议申请（法律另有规定的除外）。</li>
        <li>复议机关应当在收到申请之日起 <strong>60日内</strong> 作出复议决定（案情复杂的可延长30日）。</li>
        <li>复议请求通常包括：撤销原行政行为、变更原行政行为、确认原行政行为违法等。</li>
        <li>程序违法是最常见的申请理由，包括：未告知权利、证据未依法送达、超期作出决定等。</li>
      </ul>
    </div>

    <div style="margin-top:2.5rem;text-align:center;">
      <button class="btn btn-primary" onclick="showPage('practice')">▶ 开始练习</button>
    </div>
  </div>
</div>

<footer>
  行政复议文书练习系统 · 仅供学习练习使用 · 不构成法律建议
</footer>

<script>
// ============ APP STATE ============
const state = {
  step: 1,
  info: { applicant:'', respondent:'', actionType:'行政处罚', actionContent:'', decisionReceived:'是', hearingApplied:'否' },
  timeline: { violationDate:'', bloodDate:'', expertDate:'', decisionDate:'', deliveryDate:'' },
  issues: [],
  docApplicant: '',
  docRespondent: ''
};

const STEPS = [
  { label: '基本\n信息' }, { label: '时间\n轴' }, { label: '争议\n点' },
  { label: '规则\n匹配' }, { label: '申请\n书' }, { label: '答复\n书' }
];

const ISSUES_LIST = [
  { id:'blood', label:'抽血过程违法', desc:'抽血取样程序不合规范' },
  { id:'sample', label:'检材送检违法', desc:'送检程序存在问题' },
  { id:'expert_noserve', label:'司法鉴定意见未送达', desc:'鉴定意见未依法告知当事人' },
  { id:'late_delivery', label:'决定书送达超期', desc:'送达时间超出合理期限' },
  { id:'no_statement', label:'未告知陈述申辩权', desc:'未依法告知当事人权利' },
  { id:'no_hearing', label:'未告知听证权利', desc:'应当告知但未告知听证权利' },
  { id:'evidence_weak', label:'证据不足', desc:'主要证据不足以支持处罚决定' },
];

const RULES = {
  expert_noserve: { title:'司法鉴定意见未送达', analysis:'可能影响申请人行使陈述申辩权。依据《行政处罚法》相关规定，执法机关应当在作出处罚决定前，将主要证据告知当事人，保障其知情权与申辩权。' },
  late_delivery: { title:'决定书送达时间较晚', analysis:'送达程序可能存在程序瑕疵。决定书应当依法及时送达当事人，超期送达可能导致程序违法，影响处罚决定的合法性。' },
  no_statement: { title:'未告知陈述申辩权', analysis:'可能构成程序违法。《行政处罚法》第七条明确规定，作出行政处罚决定前，必须依法告知当事人享有陈述和申辩的权利，否则处罚决定不能成立。' },
  blood: { title:'抽血过程存在违规风险', analysis:'抽血取样程序需符合相关法规和操作规范。如取样人员资质不符、程序不规范，可能导致该鉴定意见不具备合法的证明效力。' },
  sample: { title:'检材送检程序存疑', analysis:'检材的保存与送检须符合规范，否则影响鉴定意见的合法性与客观性。如检材保管链条存在断点，鉴定意见的证明力将受到严重质疑。' },
  no_hearing: { title:'未依法告知听证权利', analysis:'对于吊销许可证等较重处罚，行政机关应依法告知当事人申请听证的权利。未告知听证权利，属于重大程序违法，可能导致处罚决定被撤销。' },
  evidence_weak: { title:'主要证据不充分', analysis:'行政处罚应以充分、确凿的证据为基础。若主要证据存在瑕疵或证明力不足，则处罚决定缺乏事实依据，依法应予撤销或变更。' },
};

// ============ PAGE NAVIGATION ============
function showPage(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  const idx = ['home','practice','help'].indexOf(name);
  document.querySelectorAll('.nav-link')[idx].classList.add('active');
  if (name === 'practice') renderStep();
  window.scrollTo(0, 0);
}

// ============ FAQ TOGGLE ============
function toggleFaq(el) {
  const ans = el.nextElementSibling;
  const icon = el.querySelector('span');
  ans.classList.toggle('open');
  icon.textContent = ans.classList.contains('open') ? '－' : '＋';
}

// ============ PROGRESS BAR ============
function renderProgress() {
  const bar = document.getElementById('progressBar');
  bar.innerHTML = '';
  STEPS.forEach((s, i) => {
    if (i > 0) {
      const line = document.createElement('div');
      line.className = 'step-line' + (state.step > i ? ' done' : '');
      bar.appendChild(line);
    }
    const wrap = document.createElement('div');
    wrap.className = 'step-dot';
    const cls = state.step === i+1 ? 'active' : state.step > i+1 ? 'done' : '';
    wrap.innerHTML = `<div class="dot ${cls}">${state.step > i+1 ? '✓' : i+1}</div><div class="dot-label" style="white-space:pre-line;">${s.label}</div>`;
    bar.appendChild(wrap);
  });
}

// ============ STEP RENDERING ============
function renderStep() {
  renderProgress();
  const c = document.getElementById('stepContent');
  if (state.step === 1) renderStep1(c);
  else if (state.step === 2) renderStep2(c);
  else if (state.step === 3) renderStep3(c);
  else if (state.step === 4) renderStep4(c);
  else if (state.step === 5) renderStep5(c);
  else if (state.step === 6) renderStep6(c);
}

function field(label, id, type, value, optionsOrPlaceholder) {
  let input = '';
  if (type === 'select') {
    input = `<select id="${id}" onchange="updateState('${id}',this.value)">${optionsOrPlaceholder.map(o=>`<option value="${o}" ${value===o?'selected':''}>${o}</option>`).join('')}</select>`;
  } else if (type === 'date') {
    input = `<input type="date" id="${id}" value="${value}" onchange="updateState('${id}',this.value)">`;
  } else {
    input = `<input type="text" id="${id}" value="${value}" placeholder="${optionsOrPlaceholder||''}" onchange="updateState('${id}',this.value)">`;
  }
  return `<div class="field-group"><label class="field-label">${label}</label>${input}</div>`;
}

function updateState(key, val) {
  if (key in state.info) state.info[key] = val;
  if (key in state.timeline) state.timeline[key] = val;
}

function renderStep1(c) {
  c.innerHTML = `
  <div class="card">
    <div class="section-title">第一步：案件基本信息</div>
    <div class="info-box">请填写模拟案件的基本信息（均为虚构人物，仅供练习）</div>
    <div class="grid-2">
      ${field('申请人姓名（假名）','applicant','text',state.info.applicant,'例：张某')}
      ${field('被申请人机关','respondent','text',state.info.respondent,'例：某市公安局交通警察支队')}
    </div>
    ${field('行政行为类型','actionType','select',state.info.actionType,['行政处罚','行政强制','不履行职责','信息公开','行政许可'])}
    ${field('处罚/行政行为具体内容','actionContent','text',state.info.actionContent,'例：吊销机动车驾驶证')}
    <div class="grid-2">
      ${field('是否收到决定书','decisionReceived','select',state.info.decisionReceived,['是','否'])}
      ${field('是否申请过听证','hearingApplied','select',state.info.hearingApplied,['否','是'])}
    </div>
  </div>
  <div class="btn-row">
    <span></span>
    <button class="btn btn-primary" onclick="goNext()">下一步：填写时间轴 →</button>
  </div>`;
}

function renderStep2(c) {
  c.innerHTML = `
  <div class="card">
    <div class="section-title">第二步：案件时间轴</div>
    <div class="info-box">时间轴是发现程序违法的关键。请尽量填写所有已知时间节点。</div>
    <div class="grid-2">
      ${field('违法行为发生时间','violationDate','date',state.timeline.violationDate)}
      ${field('抽血取样时间','bloodDate','date',state.timeline.bloodDate)}
      ${field('鉴定意见出具时间','expertDate','date',state.timeline.expertDate)}
      ${field('处罚决定作出时间','decisionDate','date',state.timeline.decisionDate)}
      ${field('决定书送达时间','deliveryDate','date',state.timeline.deliveryDate)}
    </div>
  </div>
  <div id="timelinePreview"></div>
  <div class="btn-row">
    <button class="btn btn-outline" onclick="goBack()">← 返回</button>
    <button class="btn btn-primary" onclick="goNext()">下一步：选择争议点 →</button>
  </div>`;
  renderTimelinePreview();
  // live update on date change
  document.querySelectorAll('input[type=date]').forEach(el => {
    el.addEventListener('input', () => { updateState(el.id, el.value); renderTimelinePreview(); });
  });
}

function renderTimelinePreview() {
  const tl = state.timeline;
  const events = [
    [tl.violationDate, '发生交通违法行为'],
    [tl.bloodDate, '抽血取样'],
    [tl.expertDate, '出具司法鉴定意见'],
    [tl.decisionDate, '作出行政处罚决定'],
    [tl.deliveryDate, '送达处罚决定书'],
  ].filter(e => e[0]);
  const prev = document.getElementById('timelinePreview');
  if (!events.length) { prev.innerHTML = ''; return; }
  events.sort((a,b) => a[0].localeCompare(b[0]));
  prev.innerHTML = `<div class="card"><div class="section-title" style="font-size:15px;">时间轴预览</div>${
    events.map((e,i) => `
    <div class="timeline-item">
      <div style="width:96px;font-size:13px;color:var(--text2);flex-shrink:0;">${e[0]}</div>
      <div class="timeline-dot-wrap">
        <div class="t-dot"></div>
        ${i < events.length-1 ? '<div class="t-line"></div>' : ''}
      </div>
      <div style="font-size:14px;padding-top:2px;">${e[1]}</div>
    </div>`).join('')
  }</div>`;
}

function renderStep3(c) {
  c.innerHTML = `
  <div class="card">
    <div class="section-title">第三步：争议点选择</div>
    <p style="font-size:13px;color:var(--text2);margin-bottom:1rem;">勾选本案可能存在的问题（可多选）</p>
    <div class="checkbox-group">
    ${ISSUES_LIST.map(issue => `
      <label class="checkbox-item ${state.issues.includes(issue.id)?'checked':''}" onclick="toggleIssue('${issue.id}',this)">
        <input type="checkbox" ${state.issues.includes(issue.id)?'checked':''}>
        <div class="checkbox-text">${issue.label}<small>${issue.desc}</small></div>
      </label>`).join('')}
    </div>
  </div>
  <div class="btn-row">
    <button class="btn btn-outline" onclick="goBack()">← 返回</button>
    <button class="btn btn-primary" onclick="goNext()">下一步：查看规则分析 →</button>
  </div>`;
}

function toggleIssue(id, el) {
  const idx = state.issues.indexOf(id);
  if (idx >= 0) { state.issues.splice(idx,1); el.classList.remove('checked'); el.querySelector('input').checked = false; }
  else { state.issues.push(id); el.classList.add('checked'); el.querySelector('input').checked = true; }
}

function renderStep4(c) {
  const matched = state.issues.map(id => RULES[id]).filter(Boolean);
  c.innerHTML = `
  <div class="card">
    <div class="section-title">第四步：法律规则匹配</div>
    ${matched.length === 0
      ? '<div class="empty-state"><div class="icon">📋</div><div>未选择任何争议点，请返回上一步勾选</div></div>'
      : matched.map((r,i) => `
        <div class="rule-match">
          <div class="rule-title">${i+1}. ${r.title}</div>
          <div class="rule-desc">${r.analysis}</div>
        </div>`).join('')
    }
  </div>
  <div class="btn-row">
    <button class="btn btn-outline" onclick="goBack()">← 返回</button>
    <button class="btn btn-primary" onclick="goNext()">下一步：生成申请书 →</button>
  </div>`;
}

function renderStep5(c) {
  c.innerHTML = `
  <div class="card">
    <div class="section-title">第五步：行政复议申请书</div>
    <div class="info-box">点击下方按钮，AI 将根据您填写的案件信息自动生成文书草稿（需要网络连接）。</div>
    <div id="docApplicantContent">
      ${state.docApplicant
        ? `<div style="display:flex;justify-content:flex-end;margin-bottom:8px;"><button class="copy-btn" onclick="copyDoc('applicant')">📋 复制文书</button></div><div class="doc-output">${escHtml(state.docApplicant)}</div>`
        : '<div class="empty-state"><div class="icon">✦</div><div>点击下方按钮，AI 将生成申请书草稿</div></div>'}
    </div>
  </div>
  <div class="btn-row">
    <button class="btn btn-outline" onclick="goBack()">← 返回</button>
    <div class="btn-row-right">
      <button class="btn btn-green" id="genApplicantBtn" onclick="generateDoc('applicant')">✦ AI 生成申请书</button>
      <button class="btn btn-primary" id="nextBtn5" onclick="goNext()" ${!state.docApplicant?'disabled':''}>下一步：生成答复书 →</button>
    </div>
  </div>`;
}

function renderStep6(c) {
  c.innerHTML = `
  <div class="card">
    <div class="section-title">第六步：被申请人答复书</div>
    <div class="info-box">模拟被申请人视角，AI 将生成维持原决定的答复书，用于对比练习两种立场的写作方式。</div>
    <div id="docRespondentContent">
      ${state.docRespondent
        ? `<div style="display:flex;justify-content:flex-end;margin-bottom:8px;"><button class="copy-btn" onclick="copyDoc('respondent')">📋 复制文书</button></div><div class="doc-output">${escHtml(state.docRespondent)}</div>`
        : '<div class="empty-state"><div class="icon">✦</div><div>点击下方按钮，AI 将生成答复书草稿</div></div>'}
    </div>
  </div>
  <div class="btn-row">
    <button class="btn btn-outline" onclick="goBack()">← 返回</button>
    <div class="btn-row-right">
      <button class="btn btn-green" id="genRespondentBtn" onclick="generateDoc('respondent')">✦ AI 生成答复书</button>
      <button class="btn btn-outline" onclick="restartAll()">🔄 重新开始新案件</button>
    </div>
  </div>`;
}

function goNext() { if (state.step < 6) { state.step++; renderStep(); window.scrollTo(0,0); } }
function goBack() { if (state.step > 1) { state.step--; renderStep(); window.scrollTo(0,0); } }

function restartAll() {
  if (!confirm('确定要重新开始？当前所有填写内容将被清空。')) return;
  Object.assign(state, { step:1, info:{applicant:'',respondent:'',actionType:'行政处罚',actionContent:'',decisionReceived:'是',hearingApplied:'否'}, timeline:{violationDate:'',bloodDate:'',expertDate:'',decisionDate:'',deliveryDate:''}, issues:[], docApplicant:'', docRespondent:'' });
  renderStep(); window.scrollTo(0,0);
}

function escHtml(str) {
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function copyDoc(type) {
  const text = type === 'applicant' ? state.docApplicant : state.docRespondent;
  navigator.clipboard.writeText(text).then(() => alert('文书已复制到剪贴板'));
}

// ============ BUILD CONTEXT ============
function buildContext() {
  const tl = state.timeline;
  const matched = state.issues.map(id => RULES[id]).filter(Boolean);
  return {
    applicant: state.info.applicant || '申请人',
    respondent: state.info.respondent || '被申请人机关',
    actionType: state.info.actionType,
    actionContent: state.info.actionContent || '行政处罚',
    decisionReceived: state.info.decisionReceived,
    hearingApplied: state.info.hearingApplied,
    timeline: `违法行为时间：${tl.violationDate||'未填写'}，抽血取样时间：${tl.bloodDate||'未填写'}，鉴定意见出具时间：${tl.expertDate||'未填写'}，处罚决定作出时间：${tl.decisionDate||'未填写'}，决定书送达时间：${tl.deliveryDate||'未填写'}`,
    issues: matched.map(r => r.title).join('；') || '无特别争议',
    issuesDetail: matched.map((r,i) => `${i+1}. ${r.title}：${r.analysis}`).join('\n')
  };
}

// ============ AI GENERATION ============
async function generateDoc(type) {
  const ctx = buildContext();
  const btnId = type === 'applicant' ? 'genApplicantBtn' : 'genRespondentBtn';
  const contentId = type === 'applicant' ? 'docApplicantContent' : 'docRespondentContent';
  const btn = document.getElementById(btnId);
  const contentDiv = document.getElementById(contentId);

  btn.disabled = true;
  btn.innerHTML = `<span class="loading-pulse"><span></span><span></span><span></span></span> 生成中...`;
  contentDiv.innerHTML = `<div style="padding:1.5rem;color:var(--text2);font-size:13px;display:flex;align-items:center;gap:8px;"><span class="loading-pulse" style="color:var(--purple-mid);"><span></span><span></span><span></span></span> AI 正在生成文书草稿，请稍候（约15-30秒）...</div>`;

  let prompt = '';
  if (type === 'applicant') {
    prompt = `你是中国行政法律专业人士，请根据以下模拟案件信息，生成一份完整、格式规范的行政复议申请书草稿。

注意：这是模拟练习材料，不涉及真实案件。

【案件信息】
申请人：${ctx.applicant}
被申请人：${ctx.respondent}
行政行为类型：${ctx.actionType}
行政行为具体内容：${ctx.actionContent}
是否收到决定书：${ctx.decisionReceived}
是否申请过听证：${ctx.hearingApplied}
案件时间轴：${ctx.timeline}
主要争议点：${ctx.issues}

【争议点详细分析】
${ctx.issuesDetail}

请生成完整的行政复议申请书，格式包括：
1. 申请人、被申请人基本信息
2. 复议请求（请求撤销该行政处罚决定）
3. 事实与理由（围绕上述争议点逐条展开，说明程序违法或实体问题）
4. 结语及提交声明
5. 落款（申请人：${ctx.applicant}，日期处留空）

使用正式法律文书格式，语言严谨，逻辑清晰。`;
  } else {
    prompt = `你是中国行政法律专业人士，请根据以下模拟案件信息，从被申请人角度生成一份行政复议答复书草稿。

注意：这是模拟练习材料，不涉及真实案件。

【案件信息】
申请人：${ctx.applicant}
被申请人：${ctx.respondent}
行政行为类型：${ctx.actionType}
行政行为具体内容：${ctx.actionContent}
案件时间轴：${ctx.timeline}
申请人提出的争议：${ctx.issues}

请以被申请人立场，生成完整的行政复议答复书，格式包括：
1. 文书抬头（行政复议答复书）
2. 答复人（被申请人）基本信息
3. 逐一回应申请人提出的各争议点，说明执法程序合法合规
4. 根据时间轴说明事实经过
5. 答复意见（请求复议机关维持原行政处罚决定）
6. 落款（被申请人：${ctx.respondent}，日期处留空）

使用正式法律文书格式，立场鲜明，逻辑严密。`;
  }

  try {
    const resp = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        messages: [{ role: 'user', content: prompt }]
      })
    });
    const data = await resp.json();
    const text = data.content?.map(b => b.text || '').join('') || '生成失败，请重试。';
    if (type === 'applicant') {
      state.docApplicant = text;
      contentDiv.innerHTML = `<div style="display:flex;justify-content:flex-end;margin-bottom:8px;"><button class="copy-btn" onclick="copyDoc('applicant')">📋 复制文书</button></div><div class="doc-output">${escHtml(text)}</div>`;
      document.getElementById('nextBtn5').disabled = false;
    } else {
      state.docRespondent = text;
      contentDiv.innerHTML = `<div style="display:flex;justify-content:flex-end;margin-bottom:8px;"><button class="copy-btn" onclick="copyDoc('respondent')">📋 复制文书</button></div><div class="doc-output">${escHtml(text)}</div>`;
    }
  } catch(e) {
    contentDiv.innerHTML = `<div style="padding:1rem;background:#FCEBEB;border-radius:6px;font-size:13px;color:#A32D2D;">生成失败，请检查网络连接后点击重新生成。<br><small style="opacity:0.7;">${e.message}</small></div>`;
  }

  btn.disabled = false;
  btn.innerHTML = '✦ 重新生成';
}

// Init
renderStep();
</script>
